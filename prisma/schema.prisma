generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model AnalysisSession {
  id                  String           @id @default(cuid())
  userId              String?
  title               String
  status              AnalysisStatus   @default(PENDING)
  overallScore        Int?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  user                User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  uploadedFile        UploadedFile?
  parsedResume        ParsedResume?
  jobDescription      JobDescription?
  scoringSummary      ScoringSummary?
  keywordResults      KeywordResult[]
  suggestions         Suggestion[]
}

model User {
  id            String            @id @default(cuid())
  email         String            @unique
  passwordHash  String
  name          String
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  analyses      AnalysisSession[]
  sessions      AuthSession[]
}

model AuthSession {
  id         String    @id @default(cuid())
  token      String    @unique
  userId     String
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model JobDescriptionCache {
  id                   String    @id @default(cuid())
  hash                 String    @unique
  rawText              String
  normalizedText       String
  title                String?
  company              String?
  seniority            String?
  requiredYearsExperience Int?
  extractedKeywords    Json
  mustHaveKeywords     Json
  niceToHaveKeywords   Json
  filteredOutPhrases   Json
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model UploadedFile {
  id                String           @id @default(cuid())
  sessionId         String           @unique
  originalName      String
  storagePath       String
  mimeType          String
  extension         String
  sizeBytes         Int
  uploadStatus      UploadStatus     @default(COMPLETED)
  createdAt         DateTime         @default(now())
  analysisSession   AnalysisSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model ParsedResume {
  id                String           @id @default(cuid())
  sessionId         String           @unique
  rawText           String
  normalizedText    String
  summary           String?
  hasSummary        Boolean          @default(false)
  hasSkills         Boolean          @default(false)
  hasExperience     Boolean          @default(false)
  hasEducation      Boolean          @default(false)
  hasProjects       Boolean          @default(false)
  structureScore    Int              @default(0)
  createdAt         DateTime         @default(now())
  analysisSession   AnalysisSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model JobDescription {
  id                   String           @id @default(cuid())
  sessionId            String           @unique
  rawText              String
  normalizedText       String
  title                String?
  company              String?
  seniority            String?
  requiredYearsExperience Int?
  extractedKeywords    Json
  mustHaveKeywords     Json
  niceToHaveKeywords   Json
  createdAt            DateTime         @default(now())
  analysisSession      AnalysisSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model KeywordResult {
  id                  String            @id @default(cuid())
  sessionId           String
  keyword             String
  normalizedKeyword   String
  category            KeywordCategory
  matchType           KeywordMatchType
  occurrences         Int               @default(0)
  createdAt           DateTime          @default(now())
  analysisSession     AnalysisSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model ScoringSummary {
  id                        String           @id @default(cuid())
  sessionId                 String           @unique
  keywordMatchScore         Int
  mustHaveSkillScore        Int
  sectionCompletenessScore  Int
  roleRelevanceScore        Int
  structureQualityScore     Int
  alignmentScore            Int
  bonusScore                Int              @default(0)
  explanation               Json
  createdAt                 DateTime         @default(now())
  analysisSession           AnalysisSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Suggestion {
  id                String            @id @default(cuid())
  sessionId         String
  title             String
  description       String
  priority          SuggestionPriority
  suggestionType    SuggestionType
  createdAt         DateTime          @default(now())
  analysisSession   AnalysisSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

enum AnalysisStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum UploadStatus {
  PENDING
  COMPLETED
  FAILED
}

enum KeywordCategory {
  TECHNICAL_SKILL
  SOFT_SKILL
  TOOL
  QUALIFICATION
  DOMAIN
}

enum KeywordMatchType {
  MATCHED
  MISSING
  PARTIAL
}

enum SuggestionPriority {
  LOW
  MEDIUM
  HIGH
}

enum SuggestionType {
  KEYWORD
  SECTION
  STRUCTURE
  CONTENT
  READABILITY
}
